# 数据库配置 (生产环境)
DATABASE_URL="postgresql://qkeviz_user:secure_password@localhost/qkeviz_db"

# Redis配置
REDIS_URL="redis://localhost:6379/2"

# 应用配置
APP_NAME="QKE-Viz"
APP_VERSION="1.0.0"
DEBUG=False

# 量子计算配置
QISKIT_BACKEND="aer_simulator"

# 安全配置 (生产环境 - 请在实际部署时设置强密钥)
APP_TOKEN_SECRET="your-strong-token-secret-here-change-in-production"
APP_MASTER_KEY="your-strong-master-key-here-change-in-production"
APP_TOKEN_EXPIRE_HOURS="24"