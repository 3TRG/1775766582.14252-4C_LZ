# ==================== QKE-Viz 统一环境配置 ====================
# 复制此文件为 .env 并根据实际环境修改配置

# ==================== 应用配置 ====================
ENVIRONMENT=production
APP_NAME=QKE-Viz
APP_VERSION=1.0.0
APP_DESCRIPTION=量子密钥分发可视化系统

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
RELOAD=false
WORKERS=1

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://qkeviz:${POSTGRES_PASSWORD}@db:5432/qkeviz
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# PostgreSQL 配置
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ==================== 安全配置 ====================
APP_TOKEN_SECRET=your-super-secret-token-key-change-in-production
APP_MASTER_KEY=your-master-key-32-bytes-minimum-required
APP_TOKEN_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== QKE 引擎配置 ====================
QKE_DEFAULT_BACKEND=local_simulator
QKE_DEFAULT_KEY_LENGTH=256
QKE_DEFAULT_DECOY_COUNT=4
QKE_SESSION_TIMEOUT_MINUTES=30
QKE_MAX_PARTICIPANTS=10

# ==================== CORS 配置 ====================
# 允许的前端域名，多个用逗号分隔，* 表示允许所有
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:80

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# 日志文件路径（留空则只输出到控制台）
LOG_FILE_PATH=/app/logs/qke-viz.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ==================== 监控配置 ====================
ENABLE_METRICS=true
GRAFANA_ADMIN_PASSWORD=admin

# ==================== 前端配置 ====================
# Admin 前端 API 地址
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
